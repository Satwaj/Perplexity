# ======================== ENVIRONMENT ========================
# Set to 'production' for deployment, 'development' for local development
NODE_ENV=development

# ======================== SERVER CONFIGURATION ========================
PORT=3000

# ======================== DATABASE ========================
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/database_name

# ======================== JWT ========================
JWT_SECRET_KEY=your-super-secret-key-min-32-chars-long-change-this-in-production

# ======================== FRONTEND URLs ========================
# For development
FRONTEND_URL=http://localhost:5173

# For production
# FRONTEND_URL=https://your-frontend-domain.com
# BACKEND_URL=https://your-backend-domain.com

# ======================== GOOGLE OAUTH ========================
# Get these from Google Cloud Console: https://console.cloud.google.com/
# 1. Create a project
# 2. Enable Google+ API
# 3. Create OAuth 2.0 credentials (Web application)
# 4. Add authorized redirect URIs:
#    - Development: http://localhost:3000/api/auth/google/callback
#    - Production: https://your-backend-domain.com/api/auth/google/callback

GOOGLE_CLIENT_ID=your-client-id-from-google-cloud.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret-from-google-cloud
GOOGLE_API_KEY=your-google-api-key

# Note: GOOGLE_REDIRECT_URI is now dynamically set based on NODE_ENV
# Development: http://localhost:3000/api/auth/google/callback
# Production: ${BACKEND_URL}/api/auth/google/callback

# ======================== AI API KEYS ========================
MISTRAL_API_KEY=your-mistral-api-key
OPENROUTER_API_KEY=your-openrouter-api-key
GROQ_API_KEY=your-groq-api-key
TAVILY_API_KEY=your-tavily-api-key
OPENAI_API_KEY=your-openai-api-key

# ======================== PERFORMANCE SETTINGS ========================
# Compression is enabled by default
# Helmet security headers are enabled by default
# Morgan logging mode is set based on NODE_ENV

# ======================== DEPLOYMENT CHECKLIST ========================
# Before deploying:
# 1. Update MONGO_URI with production database
# 2. Set NODE_ENV=production
# 3. Update FRONTEND_URL and BACKEND_URL with production domains
# 4. Update all API keys for production
# 5. Update Google OAuth redirect URIs in Google Cloud Console
# 6. Generate a new strong JWT_SECRET_KEY
# 7. Ensure CORS origins are restricted to your domain only
